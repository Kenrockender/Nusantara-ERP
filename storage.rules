rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidImageType() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isValidDocumentType() {
      return request.resource.contentType.matches('application/pdf') ||
             request.resource.contentType.matches('application/.*document.*') ||
             request.resource.contentType.matches('application/.*sheet.*');
    }
    
    function isUnder10MB() {
      return request.resource.size < 10 * 1024 * 1024;
    }

    // Email/password bootstrap-admin session (no role claim is minted for that
    // path — only the username→custom-token flow mints one). Must match
    // firestore.rules's bootstrapAdmin() exactly so the owner is never locked
    // out. Checking the specific email (not just "claim is null") matters:
    // any other email/password account would also have a null claim, and a
    // bare null check would silently hand it config-write access too.
    function isBootstrapAdmin() {
      return isAuthenticated() &&
             request.auth.token.email != null &&
             request.auth.token.email in ['kenrockender521@gmail.com'];
    }

    // Config-writer roles (admin/manajer) carry a role claim on the custom
    // token. Everyone else (viewer/penjualan/akunting/pending) is denied
    // config writes.
    function canWriteConfig() {
      return isBootstrapAdmin() ||
             (isAuthenticated() &&
              request.auth.token.role != null &&
              request.auth.token.role in ['admin', 'manajer']);
    }

    // User uploads (images, documents). Reads are open to any authenticated staff
    // member on purpose: uploads are shared business attachments (invoice scans,
    // delivery photos) that every operator may need to view. Writes stay scoped
    // to the uploading user's own folder.
    match /uploads/{userId}/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() &&
                     request.auth.uid == userId &&
                     (isValidImageType() || isValidDocumentType()) &&
                     isUnder10MB();
    }

    // Company assets (logos, etc.) — shared branding. Anyone signed in may read,
    // but only config-writer roles may overwrite them (previously ANY signed-in
    // user, including viewer/pending, could replace the company logo).
    match /company/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if canWriteConfig() &&
                     isValidImageType() &&
                     isUnder10MB();
    }
    
    // Backups
    match /backups/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
