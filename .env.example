# Firebase Configuration — Nusantara ERP
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# VITE_FIREBASE_MEASUREMENT_ID — intentionally unused. Google Analytics is
# disabled (privacy-first); the app never loads Analytics, so no measurement
# id is needed and none is read.

# Optional: Firestore database id. Leave unset for the standard "(default)" database.
# Set only if your project uses a named database (the config layer falls back to "default").
# VITE_FIREBASE_DB_ID=(default)

# Development
VITE_USE_EMULATORS=false

# App Configuration
VITE_APP_NAME=Nusantara ERP
VITE_APP_VERSION=1.0.0
